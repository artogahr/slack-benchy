# Slack tokens (both required)
SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_APP_TOKEN=xapp-replace-me

# Channel where the live status message lives. ID (C0123ABCD) or name (#printer).
SLACK_STATUS_CHANNEL=#printer

# PrusaLink (printer must be reachable from this host)
PRUSALINK_HOST=192.168.1.50
PRUSALINK_API_KEY=
# Optional Digest auth fallback (older firmware)
PRUSALINK_USERNAME=
PRUSALINK_PASSWORD=

# Behaviour
POLL_INTERVAL_SECONDS=30
OFFLINE_AFTER_FAILURES=4
DB_PATH=./slack-benchy.sqlite3

# Cancel policy: "anyone" or "starter_only"
CANCEL_POLICY=anyone

# Webcam snapshot: auto / on / off
WEBCAM_MODE=auto

# Optional comma-separated seed for the filament inventory on first run
FILAMENT_INVENTORY_SEED=
